# Copy to `.env` and fill in. Vite exposes only vars prefixed with VITE_.

# Receives mailto: links from Contact + Start a project
VITE_CONTACT_EMAIL=ma.helaly2003@gmail.com

# WhatsApp click-to-chat (digits only, with country code, no +)
# Example: 201234567890
VITE_WHATSAPP_NUMBER=+201014689808

# Optional: Google Apps Script Web App URL to append rows to a Sheet
# See scripts/google-sheet-webapp.gs
VITE_GOOGLE_SCRIPT_URL=
